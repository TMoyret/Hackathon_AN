/.vscode
.env
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# Regenerable PDF exports of markdown docs
/docs/specs/*.pdf

# B1 weaver run artifacts (regenerable output of a run)
/b1-weaver/thread*.ndjson
# B4 UI replay output (regenerable by demo_replay.py)
/b4-ui/thread*.ndjson
*.log

# B3 capture output (recorded sittings live outside the repo)
/b3-capture/records/
/.runs/
pytest-cache-files-*/

# Local media and run outputs are too heavy or environment-specific for Git.
*.mp4
*.mov
*.mkv
*.avi
*.webm
*.wav
*.flac
/data/**/video/

# Binary working documents stay local unless explicitly reviewed for release.
*.docx

# Graphify generated output (report, graph, caches) — regenerable, referenced nowhere.
/graphify-out/
/data/

# Fine-tune dataset (~500h audio + transcripts, ~51 Go) — too heavy for Git.
/tools/finetune-offline/PACK/
*.srt
